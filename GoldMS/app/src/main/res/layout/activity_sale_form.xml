<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#2E7D32"
            app:title="Catat Penjualan"
            app:titleTextColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Harga Emas Info -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp" app:cardBackgroundColor="#E8F5E9"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Harga Emas 24K saat ini:" android:textColor="#2E7D32"/>
                <TextView android:id="@+id/tvHargaEmasInfo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Memuat..." android:textStyle="bold" android:textColor="#2E7D32"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pilih Barang -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Pilih Barang dari Inventaris" android:textStyle="bold"
            android:textColor="#1A1A1A" android:layout_marginBottom="8dp"/>

        <Spinner android:id="@+id/spinnerBarang"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="12dp"/>

        <!-- Info Barang -->
        <androidx.cardview.widget.CardView android:id="@+id/cardInfoBarang"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="10dp" android:layout_marginBottom="12dp"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/tvInfoBarang"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#333333" android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Jumlah (pcs)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etJumlah"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="number" android:text="1"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Catatan (opsional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etCatatan"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Kalkulasi -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp" app:cardBackgroundColor="#FFF8E1"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rincian Harga" android:textStyle="bold" android:textColor="#1A1A1A"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvRincian"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="-" android:textColor="#555555" android:lineSpacingMultiplier="1.6"/>
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#DDDDDD" android:layout_marginVertical="8dp"/>
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TOTAL" android:textStyle="bold" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvTotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rp 0" android:textStyle="bold" android:textSize="18sp"
                        android:textColor="#2E7D32"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button android:id="@+id/btnHitung"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="HITUNG" android:backgroundTint="#1565C0"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnSimpan"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="SIMPAN TRANSAKSI" android:backgroundTint="#2E7D32"
            android:textStyle="bold"/>

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" android:visibility="gone"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>
